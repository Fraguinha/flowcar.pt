{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "codelldb",
      "request": "launch",
      "name": "Debug",
      "program": "${workspaceFolder}/webapp/target/debug/flowcar",
      "env": {
        "POSTGRES_USER": "flowcar_user",
        "POSTGRES_PASSWORD": "flowcar_password",
        "POSTGRES_SERVICE": "127.0.0.1",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DB": "flowcar_db"
      },
      "cwd": "${workspaceFolder}/webapp",
      "preLaunchTask": "build"
    }
  ]
}
